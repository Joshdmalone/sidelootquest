// SideLootQuest — Prisma schema (SQLite via libsql adapter)
// Local dev: DATABASE_URL=file:./dev.db
// Prod: swap to Turso (DATABASE_URL=libsql://...?authToken=...) or Postgres.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// NextAuth
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Hustle settings
  taxRatePct      Int    @default(25)
  weeklyGoalCents Int    @default(0)
  timezone        String @default("America/New_York")

  accounts    Account[]
  sessions    Session[]
  tasks       Task[]
  projects    Project[]
  clients     Client[]
  tags        Tag[]
  timeEntries TimeEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------

// SQLite has no enums — we validate these via Zod at the server-action boundary.
// Priority:    "NONE" | "LOW" | "MEDIUM" | "HIGH"
// BillingType: "NONE" | "HOURLY" | "FIXED"

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#8b5cf6")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
  tasks    Task[]

  @@index([userId])
}

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("#64748b")

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@unique([userId, name])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  notes       String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  dueAt       DateTime?
  priority    String    @default("NONE") // NONE | LOW | MEDIUM | HIGH
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Hustle mode — if billable, revenue flows from this task
  billingType String @default("NONE") // NONE | HOURLY | FIXED
  rateCents   Int?
  priceCents  Int?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        TaskTag[]
  timeEntries TimeEntry[]

  @@index([userId, completed])
  @@index([userId, dueAt])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  taskId    String?
  startedAt DateTime
  endedAt   DateTime?
  seconds   Int       @default(0)

  kind String @default("focus") // focus | break | billable

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
}
