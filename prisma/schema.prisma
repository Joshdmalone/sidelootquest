// SideLootQuest — Prisma schema
// Generator is the new Prisma 7 `prisma-client` (outputs TS into src/generated/prisma).
// Import from "@/generated/prisma", NOT "@prisma/client".

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// NextAuth
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Hustle settings
  taxRatePct      Int    @default(25) // % set aside per completed paid task
  weeklyGoalCents Int    @default(0)  // weekly earnings goal, in cents
  timezone        String @default("America/New_York")

  accounts    Account[]
  sessions    Session[]
  tasks       Task[]
  projects    Project[]
  clients     Client[]
  tags        Tag[]
  timeEntries TimeEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum BillingType {
  NONE   // not billable (personal task)
  HOURLY // rateCents × hours worked
  FIXED  // fixed priceCents on completion
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#8b5cf6")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
  tasks    Task[]

  @@index([userId])
}

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("#64748b")

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks TaskTag[]

  @@unique([userId, name])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  notes       String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  dueAt       DateTime?
  priority    Priority  @default(NONE)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Hustle mode — if billable, revenue flows from this task
  billingType BillingType @default(NONE)
  rateCents   Int?
  priceCents  Int?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        TaskTag[]
  timeEntries TimeEntry[]

  @@index([userId, completed])
  @@index([userId, dueAt])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// Pomodoro / billable time. Attaching to a task = billable (kind="billable").
// Standalone focus block = kind="focus".
model TimeEntry {
  id        String    @id @default(cuid())
  userId    String
  taskId    String?
  startedAt DateTime
  endedAt   DateTime?
  seconds   Int       @default(0)

  // "focus" | "break" | "billable"
  kind String @default("focus")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
}
